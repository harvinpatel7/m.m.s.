<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>M.M.S Restaurant – Pure Veg | Rajkot</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lora:ital,wght@0,400;0,500;1,400&family=Nunito+Sans:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --saffron: #D4681A;
    --saffron-light: #F0A050;
    --saffron-pale: #FDF3E7;
    --deep-brown: #3B1F0A;
    --warm-brown: #6B3A1F;
    --clay: #A0522D;
    --cream: #FBF5EB;
    --gold: #C9922A;
    --gold-light: #E8C060;
    --leaf: #4A6741;
    --leaf-light: #7A9E72;
    --text-dark: #2A1508;
    --text-mid: #5A3520;
    --text-muted: #9A7060;
    --border: rgba(180,100,30,0.18);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Nunito Sans', sans-serif;
    background: var(--cream);
    color: var(--text-dark);
    overflow-x: hidden;
  }

  /* ── TEXTURE OVERLAY ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(212,104,26,0.04) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(201,146,42,0.05) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 3rem;
    background: rgba(251,245,235,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow 0.3s;
  }

  nav.scrolled {
    box-shadow: 0 4px 30px rgba(59,31,10,0.10);
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--saffron);
    letter-spacing: 0.03em;
  }

  .nav-logo span {
    color: var(--deep-brown);
  }

  .nav-links {
    display: flex;
    gap: 2.2rem;
    list-style: none;
  }

  .nav-links a {
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-mid);
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -3px; left: 0;
    width: 0; height: 1.5px;
    background: var(--saffron);
    transition: width 0.25s;
  }

  .nav-links a:hover { color: var(--saffron); }
  .nav-links a:hover::after { width: 100%; }

  .nav-cta {
    background: var(--saffron);
    color: #fff !important;
    padding: 0.55rem 1.4rem;
    border-radius: 2rem;
    font-size: 0.8rem !important;
    letter-spacing: 0.1em;
    transition: background 0.2s, transform 0.15s !important;
  }

  .nav-cta:hover {
    background: var(--warm-brown) !important;
    transform: translateY(-1px);
  }

  .nav-cta::after { display: none !important; }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    position: relative;
    padding: 7rem 2rem 4rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 70% at 50% 40%, rgba(212,104,26,0.08) 0%, transparent 70%),
      linear-gradient(160deg, rgba(201,146,42,0.06) 0%, transparent 50%);
  }

  /* Decorative mandala ring */
  .hero-ring {
    position: absolute;
    width: 600px; height: 600px;
    border: 1.5px solid rgba(212,104,26,0.12);
    border-radius: 50%;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    animation: spin 40s linear infinite;
  }

  .hero-ring-2 {
    width: 450px; height: 450px;
    border-color: rgba(201,146,42,0.10);
    animation-duration: 28s;
    animation-direction: reverse;
  }

  @keyframes spin { to { transform: translate(-50%, -50%) rotate(360deg); } }

  .hero-content { position: relative; z-index: 2; max-width: 780px; }

  .hero-badge {
    display: inline-block;
    font-family: 'Nunito Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(201,146,42,0.12);
    border: 1px solid rgba(201,146,42,0.3);
    padding: 0.38rem 1.2rem;
    border-radius: 2rem;
    margin-bottom: 1.6rem;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 1.08;
    color: var(--deep-brown);
    margin-bottom: 0.3rem;
  }

  .hero h1 em {
    color: var(--saffron);
    font-style: italic;
  }

  .hero-tagline {
    font-family: 'Lora', serif;
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    font-style: italic;
    color: var(--text-muted);
    margin: 1rem 0 2.2rem;
    letter-spacing: 0.02em;
  }

  .hero-divider {
    width: 60px; height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 0 auto 2.2rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--saffron);
    color: #fff;
    padding: 0.85rem 2.2rem;
    border-radius: 3rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(212,104,26,0.25);
  }

  .btn-primary:hover {
    background: var(--warm-brown);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(212,104,26,0.35);
  }

  .btn-outline {
    border: 1.5px solid var(--saffron);
    color: var(--saffron);
    padding: 0.85rem 2.2rem;
    border-radius: 3rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    background: var(--saffron);
    color: #fff;
    transform: translateY(-2px);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 3rem;
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .hero-stat .number {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--saffron);
  }

  .hero-stat .label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  /* ── SECTION COMMONS ── */
  section { position: relative; z-index: 1; }

  .section-label {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    display: block;
    margin-bottom: 0.6rem;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.9rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--deep-brown);
    line-height: 1.15;
  }

  .section-title em {
    color: var(--saffron);
    font-style: italic;
  }

  .section-subtitle {
    font-family: 'Lora', serif;
    font-style: italic;
    font-size: 1rem;
    color: var(--text-muted);
    margin-top: 0.6rem;
    max-width: 560px;
  }

  .ornament {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin: 1.2rem 0 0;
  }

  .ornament-line {
    flex: 1;
    max-width: 50px;
    height: 1.5px;
    background: linear-gradient(90deg, transparent, var(--gold-light));
  }

  .ornament-line.right {
    background: linear-gradient(90deg, var(--gold-light), transparent);
  }

  .ornament-diamond {
    width: 7px; height: 7px;
    background: var(--gold);
    transform: rotate(45deg);
  }

  /* ── ABOUT ── */
  .about {
    padding: 6rem 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
  }

  .about-visual {
    position: relative;
  }

  .about-img-frame {
    width: 100%;
    aspect-ratio: 4/5;
    background: linear-gradient(135deg, rgba(212,104,26,0.12), rgba(201,146,42,0.08));
    border-radius: 2px;
    border: 1.5px solid rgba(212,104,26,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .about-img-frame::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(212,104,26,0.15);
    border-radius: 1px;
  }

  .about-plate-icon {
    font-size: 7rem;
    opacity: 0.35;
  }

  .about-badge-float {
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    background: var(--saffron);
    color: #fff;
    width: 110px; height: 110px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: 'Playfair Display', serif;
    box-shadow: 0 8px 30px rgba(212,104,26,0.35);
  }

  .about-badge-float .big { font-size: 1.8rem; font-weight: 700; line-height: 1; }
  .about-badge-float .small { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.88; margin-top: 0.2rem; text-align: center; }

  .about-text p {
    font-size: 0.97rem;
    line-height: 1.85;
    color: var(--text-mid);
    margin-top: 1.2rem;
  }

  .about-values {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }

  .value-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.1rem 1.2rem;
  }

  .value-card .icon { font-size: 1.4rem; margin-bottom: 0.4rem; }
  .value-card .title { font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 600; color: var(--deep-brown); }
  .value-card .desc { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.3rem; line-height: 1.5; }

  /* ── MENU ── */
  .menu-section {
    background: var(--deep-brown);
    padding: 6rem 3rem;
    position: relative;
    overflow: hidden;
  }

  .menu-section::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 500px; height: 500px;
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 50%;
  }

  .menu-section::after {
    content: '';
    position: absolute;
    bottom: -80px; left: -80px;
    width: 380px; height: 380px;
    border: 1px solid rgba(212,104,26,0.12);
    border-radius: 50%;
  }

  .menu-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 2; }

  .menu-header { text-align: center; margin-bottom: 3rem; }
  .menu-header .section-label { color: var(--gold-light); }
  .menu-header .section-title { color: #fff; }
  .menu-header .section-subtitle { color: rgba(255,255,255,0.5); margin: 0.5rem auto; }

  .menu-tabs {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .tab-btn {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.6);
    padding: 0.55rem 1.4rem;
    border-radius: 2rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab-btn.active, .tab-btn:hover {
    background: var(--saffron);
    border-color: var(--saffron);
    color: #fff;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.2rem;
  }

  .menu-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 4px;
    padding: 1.4rem 1.6rem;
    transition: background 0.2s, border-color 0.2s;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .menu-card:hover {
    background: rgba(212,104,26,0.12);
    border-color: rgba(212,104,26,0.35);
  }

  .menu-card .left { flex: 1; }

  .menu-card .item-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.3rem;
  }

  .menu-card .item-desc {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.5;
  }

  .menu-card .item-badge {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 2rem;
    margin-top: 0.5rem;
  }

  .badge-bestseller { background: rgba(201,146,42,0.2); color: var(--gold-light); }
  .badge-special { background: rgba(74,103,65,0.25); color: #9FD090; }
  .badge-new { background: rgba(212,104,26,0.25); color: #F0A050; }

  .menu-card .price {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--gold-light);
    white-space: nowrap;
  }

  .menu-card .price span {
    font-size: 0.75rem;
    font-weight: 400;
    color: rgba(255,255,255,0.4);
  }

  /* ── SPECIALS ── */
  .specials {
    padding: 6rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .specials-header { margin-bottom: 3rem; }

  .specials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .special-card {
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
    background: #fff;
  }

  .special-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(59,31,10,0.12);
  }

  .special-img {
    height: 180px;
    background: linear-gradient(135deg, rgba(212,104,26,0.15), rgba(201,146,42,0.12));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 5rem;
  }

  .special-body { padding: 1.4rem 1.5rem; }

  .special-body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--deep-brown);
  }

  .special-body p {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 0.4rem;
    line-height: 1.6;
  }

  .special-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .special-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--saffron);
  }

  .tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    background: var(--saffron-pale);
    color: var(--saffron);
    border-radius: 2rem;
    border: 1px solid rgba(212,104,26,0.2);
  }

  /* ── EXPERIENCE ── */
  .experience {
    background: linear-gradient(160deg, rgba(212,104,26,0.06) 0%, rgba(201,146,42,0.04) 100%);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 5rem 3rem;
  }

  .experience-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2.5rem;
    text-align: center;
  }

  .exp-item .icon {
    font-size: 2.8rem;
    margin-bottom: 1rem;
  }

  .exp-item h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    color: var(--deep-brown);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .exp-item p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── THALI HIGHLIGHT ── */
  .thali-section {
    padding: 6rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .thali-text .section-subtitle { max-width: 100%; }

  .thali-items {
    margin-top: 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .thali-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.9rem;
    color: var(--text-mid);
  }

  .thali-dot {
    width: 8px; height: 8px;
    background: var(--saffron);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .thali-visual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .thali-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1.5rem 1.2rem;
    text-align: center;
    transition: all 0.2s;
  }

  .thali-card:hover {
    border-color: var(--saffron);
    box-shadow: 0 6px 24px rgba(212,104,26,0.10);
  }

  .thali-card .t-icon { font-size: 2.5rem; margin-bottom: 0.6rem; }
  .thali-card .t-name { font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 600; color: var(--deep-brown); }
  .thali-card .t-price { font-size: 1rem; font-weight: 700; color: var(--saffron); margin-top: 0.3rem; }

  .thali-card.featured {
    background: var(--saffron);
    border-color: var(--saffron);
    grid-column: 1 / -1;
  }

  .thali-card.featured .t-name { color: #fff; font-size: 1.1rem; }
  .thali-card.featured .t-price { color: rgba(255,255,255,0.85); font-size: 1.2rem; }

  /* ── TIMINGS ── */
  .timings-section {
    background: var(--deep-brown);
    padding: 5rem 3rem;
  }

  .timings-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 2rem;
  }

  .timing-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 4px;
    padding: 2rem 1.5rem;
    text-align: center;
  }

  .timing-card .t-icon { font-size: 2.2rem; margin-bottom: 0.8rem; }
  .timing-card .t-label { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold-light); font-weight: 600; margin-bottom: 0.4rem; }
  .timing-card .t-time { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: #fff; font-weight: 600; }
  .timing-card .t-days { font-size: 0.8rem; color: rgba(255,255,255,0.5); margin-top: 0.3rem; }

  /* ── CONTACT & LOCATION ── */
  .contact-section {
    padding: 6rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-info .section-subtitle { max-width: 100%; }

  .contact-details {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .contact-row {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-icon {
    width: 40px; height: 40px;
    background: var(--saffron-pale);
    border: 1px solid rgba(212,104,26,0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .contact-row .c-label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    font-weight: 600;
  }

  .contact-row .c-value {
    font-size: 0.95rem;
    color: var(--text-dark);
    font-weight: 500;
    margin-top: 0.1rem;
