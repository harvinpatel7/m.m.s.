    { name: 'Kids Thali', desc: 'Smaller portions of kid favourites — roti, dal, sabji & kheer.', price: '₹80', cat: 'thali', badge: '' },
    { name: 'Special Thali', desc: 'Premium thali with extra items — paneer sabji, 2 sweets & papad fry.', price: '₹240', cat: 'thali', badge: 'new' },
    { name: 'Shrikhand', desc: 'Strained yoghurt sweetened with sugar, flavoured with cardamom & saffron.', price: '₹70', cat: 'sweet', badge: 'bestseller' },
    { name: 'Aamras', desc: 'Pure Alphonso mango pulp — seasonal. Best enjoyed with hot puris.', price: '₹90', cat: 'sweet', badge: 'special' },
    { name: 'Basundi', desc: 'Thickened sweetened milk with pistachios, almonds & saffron strands.', price: '₹80', cat: 'sweet', badge: '' },
    { name: 'Gulab Jamun', desc: 'Soft milk-solid dumplings soaked in rose-flavoured sugar syrup.', price: '₹50', cat: 'sweet', badge: '' },
    { name: 'Chaas (Buttermilk)', desc: 'Chilled salted buttermilk with cumin, ginger & coriander.', price: '₹30', cat: 'drinks', badge: 'bestseller' },
    { name: 'Masala Chaas', desc: 'Spiced buttermilk with roasted cumin, black salt & mint.', price: '₹40', cat: 'drinks', badge: '' },
    { name: 'Fresh Lime Soda', desc: 'Sweet, salted or mixed. Freshly squeezed limes with chilled soda.', price: '₹45', cat: 'drinks', badge: '' },
    { name: 'Thandai', desc: 'Chilled milk blended with almonds, rose petals, fennel & saffron.', price: '₹60', cat: 'drinks', badge: 'special' },
  ];

  const badgeMap = {
    bestseller: '<span class="item-badge badge-bestseller">★ Bestseller</span>',
    special: '<span class="item-badge badge-special">Chef\'s Special</span>',
    new: '<span class="item-badge badge-new">New</span>',
    '': ''
  };

  function renderMenu(filter) {
    const grid = document.getElementById('menuGrid');
    const items = filter === 'all' ? menuItems : menuItems.filter(i => i.cat === filter);
    grid.innerHTML = items.map(item => `
      <div class="menu-card">
        <div class="left">
          <div class="item-name"><span class="veg-icon"></span> ${item.name}</div>
          <div class="item-desc">${item.desc}</div>
          ${badgeMap[item.badge]}
        </div>
        <div>
          <div class="price">${item.price}<br><span>per plate</span></div>
        </div>
      </div>
    `).join('');
  }

  function filterMenu(cat) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    event.target.classList.add('active');
    renderMenu(cat);
  }

  renderMenu('all');

  // Nav scroll
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 40);
  });

  // Fade in on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
</script>
